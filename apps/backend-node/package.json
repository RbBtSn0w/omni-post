{
    "name": "omni-post-backend-node",
    "version": "2.0.0",
    "description": "OmniPost Backend - Multi-platform content publishing service powered by Express and Playwright (TypeScript)",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "db:init": "tsx src/db/migrations.ts",
        "lint": "eslint src/ tests/",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "better-sqlite3": "^11.7.0",
        "cors": "^2.8.5",
        "express": "^4.21.0",
        "express-rate-limit": "^8.3.1",
        "multer": "^1.4.5-lts.1",
        "playwright": "^1.50.0",
        "uuid": "^11.0.0",
        "winston": "^3.17.0",
        "winston-daily-rotate-file": "^5.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@types/better-sqlite3": "^7.6.12",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/multer": "^1.4.12",
        "@types/node": "^22.10.0",
        "@types/supertest": "^6.0.2",
        "@types/uuid": "^10.0.0",
        "@vitest/coverage-v8": "^3.0.0",
        "eslint": "^9.39.2",
        "eslint-plugin-import": "^2.32.0",
        "globals": "^14.0.0",
        "supertest": "^7.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.56.1",
        "vitest": "^3.0.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
