{
  "extends": "@omni-post/shared-config/tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@omni-post/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*", "vite.config.js"]
}
