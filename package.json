{
  "name": "omni-post",
  "version": "1.2.1",
  "description": "OmniPost - Broadcast Everywhere, Manage Once. The Ultimate Multi-Platform Content Publishing Tool",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "npm install && npm run install:python",
    "install:ws": "npm install --workspaces",
    "install:all": "npm install && npm run install:backend && npm run install:node && npm run install:frontend",
    "install:python": "node tools/scripts/install-python.mjs",
    "install:backend": "npm run env:create -w apps/backend && npm run env:install -w apps/backend",
    "install:node": "npm install -w apps/backend-node",
    "install:frontend": "npm install -w apps/frontend",
    "dev": "npm run dev --workspaces",
    "dev:all": "npm run dev --workspaces",
    "dev:backend": "npm run dev -w apps/backend",
    "dev:frontend": "npm run dev -w apps/frontend",
    "dev:node": "npm run dev -w apps/backend-node",
    "build": "npm run build --workspaces",
    "build:all": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "lint:all": "npm run lint --workspaces",
    "lint:backend": "npm run lint -w apps/backend",
    "lint:node": "npm run lint -w apps/backend-node",
    "lint:frontend": "npm run lint -w apps/frontend",
    "test": "npm run test --workspaces",
    "test:all": "npm run test --workspaces",
    "test:backend": "npm run test -w apps/backend",
    "test:frontend": "npm run test -w apps/frontend",
    "test:node": "npm run test -w apps/backend-node",
    "test:frontend:coverage": "npm run test:coverage -w apps/frontend",
    "clean": "node tools/scripts/clean-workspaces.mjs",
    "check:workspace": "node tools/scripts/check-workspace.mjs",
    "prepare": "husky || true"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=9.0.0",
    "python": ">=3.10.0 <3.11.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RbBtSn0w/omni-post.git"
  },
  "homepage": "https://github.com/RbBtSn0w/omni-post#readme",
  "bugs": {
    "url": "https://github.com/RbBtSn0w/omni-post/issues"
  },
  "keywords": [
    "omni-post",
    "omnipost",
    "social-media",
    "automation",
    "multi-platform",
    "content-publishing",
    "broadcast",
    "content-creator",
    "douyin",
    "xiaohongshu",
    "playwright",
    "vue3",
    "flask",
    "typescript"
  ],
  "author": "rbbtsn0w <hamiltonsnow@gmail.com>",
  "license": "MIT",
  "notes": [
    "This is a full-stack project with separate dependencies for frontend and dual backends (Python & Node.js).",
    "Frontend dependencies are managed by npm in apps/frontend/package.json.",
    "Node.js backend dependencies are managed by npm in apps/backend-node/package.json.",
    "Python backend dependencies are managed by pip in apps/backend/requirements.txt.",
    "Python version must be 3.10.x (>=3.10.0 <3.11.0) as specified in README.md.",
    "It is recommended to run Python in a virtual environment (venv) as specified in README.md.",
    "Use the :venv suffix commands to run in a virtual environment.",
    "For example: npm run install:all:venv, npm run dev:backend:venv.",
    "Please follow the setup instructions in the README.md file."
  ],
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.2.5",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1"
  },
  "lint-staged": {
    "apps/frontend/**/*.{js,vue}": [
      "eslint --fix --config apps/frontend/eslint.config.js"
    ],
    "apps/backend-node/**/*.ts": [
      "npm run lint -w apps/backend-node"
    ],
    "packages/shared/**/*.ts": [
      "npm run lint -w @omni-post/shared"
    ],
    "apps/backend/**/*.py": [
      "apps/backend/.venv/bin/black",
      "apps/backend/.venv/bin/isort"
    ]
  }
}
