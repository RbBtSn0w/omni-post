+schema_version: "1.0"
+
+extension:
+  id: superb
+  name: Superpowers Bridge
+  version: 1.0.0
+  description: "Orchestrates obra/superpowers skills inside Spec Kit workflow. Provides commands for intent clarification, TDD, task review, verification, critique, debugging, branch completion, and code review."
+  author: rbbtsn0w
+  repository: https://github.com/RbBtSn0w/spec-kit-extensions
+  license: MIT
+  homepage: https://github.com/RbBtSn0w/spec-kit-extensions
+
+requires:
+  speckit_version: ">=0.4.3"
+  tools:
+    - name: superpowers
+      required: false
+      version: ">=5.0.0"
+
+provides:
+  commands:
+    - name: speckit.superb.clarify
+      file: commands/clarify.md
+      description: >
+        Orchestrates the superpowers brainstorming skill within the spec-kit
+        specify workflow. Loads the authoritative SKILL.md at runtime, binds
+        spec-kit context, and produces an intent summary for speckit.specify.
+
+    - name: speckit.superb.tdd
+      file: commands/tdd.md
+      description: >
+        Mandatory pre-implement gate. Loads the superpowers TDD skill at
+        runtime and binds it to spec-kit's tasks.md task structure. Enforces
+        RED-GREEN-REFACTOR for every task.
+
+    - name: speckit.superb.review
+      file: commands/review.md
+      description: >
+        Verify the generated tasks.md covers every requirement in spec.md.
+        Produces a gap report before implementation begins so missing coverage
+        is caught at planning time, not delivery time. Bridge-original command.
+
+    - name: speckit.superb.verify
+      file: commands/verify.md
+      description: >
+        Mandatory completion gate. Loads the superpowers verification skill
+        at runtime and extends it with spec-kit's spec-coverage checklist.
+        No task may be marked done without fresh evidence.
+
+    - name: speckit.superb.critique
+      file: commands/critique.md
+      description: >
+        Persistent spec-aligned code-review agent. Loads spec.md, plan.md, and
+        tasks.md, then reviews every diff against the declared requirements,
+        reporting issues by severity (Critical / Important / Minor). Bridge-original command.
+
+    - name: speckit.superb.debug
+      file: commands/debug.md
+      description: >
+        Systematic debugging protocol. Loads the superpowers systematic-debugging
+        skill at runtime. Enforces root-cause investigation before any fix attempt.
+        Escalation path from the TDD gate when 2+ fixes fail.
+
+    - name: speckit.superb.finish
+      file: commands/finish.md
+      description: >
+        Development branch completion. Loads the superpowers finishing skill at
+        runtime. Presents structured options (merge / PR / keep / discard) after
+        verification passes. Call after verify succeeds.
+
+    - name: speckit.superb.respond
+      file: commands/respond.md
+      description: >
+        Code review response protocol. Loads the superpowers receiving-code-review
+        skill at runtime. Enforces technical verification before implementing
+        feedback. Pairs with critique as the implementer counterpart.
+
+  config:
+    - name: superb-config.yml
+      template: superb-config.template.yml
+      description: "Superpowers Bridge configuration"
+      required: false
+
+hooks:
+  before_specify:
+    command: speckit.superb.clarify
+    optional: true
+    prompt: "Run intent-clarification before writing the spec? (recommended for new features)"
+    description: >
+      Socratic design refinement via the superpowers brainstorming skill.
+      Ensures the spec captures the real requirement, not just the stated one.
+
+  before_implement:
+    command: speckit.superb.tdd
+    optional: false
+    description: >
+      Mandatory TDD gate. Loads the superpowers test-driven-development skill
+      and binds it to the spec-kit task structure before any code is written.
+
+  after_tasks:
+    command: speckit.superb.review
+    optional: true
+    prompt: "Review tasks.md against spec.md for coverage gaps before implementation?"
+    description: >
+      Catches missing or under-specified tasks at planning time. Produces a
+      spec-coverage matrix with gap identification. Bridge-original logic.
+
+  after_implement:
+    command: speckit.superb.verify
+    optional: false
